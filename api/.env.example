# =============================================================================
# Application Configuration
# =============================================================================

# Application code (used for generating unique identifiers, defaults to package.json name)
APP_CODE=APP_CODE
# Enable application logging
LOGGER_ENABLED=true

# API route prefix (applies to REST and Swagger routes only; GraphQL uses GRAPHQL_ENDPOINT directly)
API_PREFIX=/api

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL database connection
# Write Database URI (for write operations - commands, mutations)
# Format: postgresql://username:password@host:port/database
# Example: WRITE_DATABASE_URI=postgresql://postgres:postgres@localhost:5432/postgres_write
WRITE_DATABASE_URI=postgresql://postgres:postgres@localhost:5432/postgres_write

# Read Database URI (for read operations - queries)
# Format: postgresql://username:password@host:port/database
# Example: READ_DATABASE_URI=postgresql://postgres:postgres@localhost:5432/postgres_read
READ_DATABASE_URI=postgresql://postgres:postgres@localhost:5432/postgres_read

# Enable database query logging (set to 'true' to enable)
DB_LOGGING_ENABLED=false

# =============================================================================
# Firebase Configuration
# =============================================================================

# Firebase Service Account JSON (as a string)
# This should be the entire JSON object as a single-line string
# Example: FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'
# If not provided, will attempt to use default credentials (e.g., from Google Cloud environment)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase Web API Key
# This is the Web API Key from Firebase Console > Project Settings > General
# Used for password verification via Firebase REST API
FIREBASE_API_KEY=

# =============================================================================
# API Documentation (Swagger)
# =============================================================================

# Enable Swagger/OpenAPI documentation (set to 'true' to enable)
SWAGGER_ENABLED=true

# Swagger documentation route (default: '/docs', combined with API_PREFIX, e.g. '/api/docs')
SWAGGER_DOCUMENTATION_ROUTE=/api

# OpenAPI JSON route is derived automatically from SWAGGER_DOCUMENTATION_ROUTE
# Example: '/api/docs' -> '/api/docs.json'

# Swagger contact information (optional)
SWAGGER_CONTACT_NAME=
SWAGGER_CONTACT_EMAIL=
SWAGGER_CONTACT_URL=

# Swagger server URLs (optional, for documentation purposes)
SWAGGER_PRODUCTION_URL=

# =============================================================================
# Rate Limiting
# =============================================================================

# Enable rate limiting (set to 'true' to enable)
RATE_LIMIT_ENABLED=true

# Maximum requests per time window (default: 100)
RATE_LIMIT_MAX=1000

# Time window for rate limiting in milliseconds (default: 60000)
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# CORS Configuration
# =============================================================================

# Enable CORS (set to 'true' to enable)
CORS_ENABLED=true

# Comma-separated list of allowed origins
# If not set and CORS_ENABLED is true, allows all origins
# Example: CORS_ORIGINS=http://localhost:3000,https://example.com
CORS_ORIGINS=

# =============================================================================
# Pagination Configuration
# =============================================================================

# Default number of items per page (default: 50)
PAGINATION_DEFAULT_ITEMS_PER_PAGE=50

# Maximum number of items per page (default: 100)
PAGINATION_MAX_ITEMS_PER_PAGE=100

# Maximum search term length (default: 50)
SEARCH_TERM_MAX_LENGTH=50

# =============================================================================
# JWT Configuration
# =============================================================================

# JWT Private Key (optional, takes precedence over FIREBASE_SERVICE_ACCOUNT_JSON private key)
# If set, this private key will be used for signing JWT access tokens
# Example: JWT_PRIVATE_KEY='-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----'
JWT_PRIVATE_KEY=

# JWT Public Key (optional, derived from JWT_PRIVATE_KEY if omitted)
JWT_PUBLIC_KEY=

# JWT Issuer (optional, defaults to 'issuer')
# Used as the 'iss' claim in JWT tokens when JWT_PRIVATE_KEY is set
# If not set and JWT_PRIVATE_KEY is used, defaults to 'issuer'
JWT_ISSUER=

# JWT Access Token Expiration Time (optional, defaults to '15m')
# Accepts values like '15m', '1h', '2h', '1d', etc.
# Examples: '15m' (15 minutes), '1h' (1 hour), '2h' (2 hours), '1d' (1 day)
JWT_ACCESS_TOKEN_EXPIRES_IN=15m

# =============================================================================
# GraphQL Configuration
# =============================================================================

# Enable GraphQL endpoint (set to 'false' to disable)
GRAPHQL_ENABLED=true

# Enable GraphiQL UI (set to 'true' to enable the GraphQL UI)
GRAPHIQL_ENABLED=false

# GraphQL endpoint route (default: '/graphql', not affected by API_PREFIX)
# This is where GraphQL queries/mutations are POSTed
GRAPHQL_ENDPOINT=/graphql
