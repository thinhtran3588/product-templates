{
  "name": "nodejs-api-starter-kit",
  "version": "0.1.1",
  "description": "API Demo",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --minify --outdir ./dist --sourcemap --target=bun",
    "start": "bun run src/index.ts",
    "dev": "bun run --env-file=.env --env-file=.env.development --hot src/index.ts",
    "dev:prod": "bun run --env-file=.env --env-file=.env.production --hot src/index.ts",
    "test": "bun run vitest run --reporter=verbose",
    "test:watch": "bun run vitest",
    "test:ui": "bun run vitest --ui",
    "test:coverage": "bun run vitest run --coverage",
    "test:unit": "bun run vitest run src/__tests__/unit",
    "test:e2e": "bun run vitest run src/__tests__/e2e",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "validate": "bun --bun tsc --noEmit && npm run lint && npm run format:check && npm run test:coverage && npm run build",
    "migrate": "bun database/migrate.ts up",
    "migrate:down": "bun database/migrate.ts down",
    "migrate:status": "bun database/migrate.ts status",
    "migrate:create": "bun database/create-migration.ts",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy"
  },
  "keywords": [],
  "author": "Thinh Tran",
  "license": "MIT",
  "dependencies": {
    "@hono/graphql-server": "^0.7.0",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.2",
    "awilix": "^12.0.5",
    "drizzle-orm": "^0.45.1",
    "firebase-admin": "^13.6.0",
    "graphql": "^16.12.0",
    "hono": "^4.12.2",
    "hono-rate-limiter": "^0.5.3",
    "html-entities": "^2.6.0",
    "is-mergeable-object": "^1.1.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "sanitize-html": "^2.17.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@types/bun": "^1.3.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.1",
    "@types/pg": "^8.15.6",
    "@types/sanitize-html": "^2.16.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/coverage-v8": "^4.0.14",
    "@vitest/ui": "^4.0.14",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-prettier": "^5.5.4",
    "glob": "^13.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.14",
    "wrangler": "^4.69.0"
  }
}
